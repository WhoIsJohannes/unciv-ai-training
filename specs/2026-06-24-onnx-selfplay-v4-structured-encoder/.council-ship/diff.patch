+    ("emb", "slot"),        # 10 unit_owner_slot (SHARED slot table; 255 -> reindex)
+    ("emb", "unit_type"),   # 11 unit_type_cat (0..4)
+    ("num",),               # 12 unit_health_bucket
+)
